{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ForumDb;User Id=sa;Password=Quorum_Demo2026!;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "replace-with-any-random-string-of-64-or-more-characters-xxxxxxxxxxxx"
  }
}
