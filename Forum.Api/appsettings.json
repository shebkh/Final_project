{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ForumDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "Forum.Api",
    "Audience": "Forum.Web",
    "AccessTokenExpiryMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7225", "http://localhost:5143" ]
  }
}
