@* Forum.Web/Components/Layout/MainLayout.razor *@
@* Static SSR layout. A layout must NOT declare @rendermode: @Body is a
   RenderFragment and cannot be serialized across a render-mode boundary.
   Each page owns its own render mode; the interactive auth controls live in
   <NavAuthControls>, which declares its own. *@
@inherits LayoutComponentBase

<header class="top-bar">
    <a class="brand" href="/">Discussion Forum</a>
    <nav class="top-nav">
        <a href="/threads">Threads</a>
        <a href="/categories">Categories</a>
        <a href="/search">Search</a>
        <NavAuthControls />
    </nav>
</header>

<main class="content">
    @Body
</main>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
