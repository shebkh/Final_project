@* Forum.Web/Features/Categories/CategoryPicker.razor *@
@* Embedded category dropdown (no @page / @rendermode — inherits the host page's
   render mode; all hosts are interactive, which MudSelect's popover requires).
   Self-loads the category list; roots first with their children indented
   beneath them. Binds an optional CategoryId via @bind-Value. *@
@inject ICategoryApiClient CategoryApi

<MudSelect T="int?" Value="Value" ValueChanged="OnValueChangedAsync" Label="@Label"
           Disabled="@(Disabled || _loading)" Variant="Variant.Outlined" Margin="Margin.Dense"
           ToStringFunc="DisplayName" id="@Id">
    <MudSelectItem T="int?" Value="@((int?)null)">@EmptyLabel</MudSelectItem>
    @foreach (var root in Roots)
    {
        <MudSelectItem T="int?" Value="@((int?)root.Id)">@root.Name</MudSelectItem>
        @foreach (var child in ChildrenOf(root.Id))
        {
            <MudSelectItem T="int?" Value="@((int?)child.Id)">— @child.Name</MudSelectItem>
        }
    }
</MudSelect>
@if (_error is not null)
{
    <p class="forum-hint" role="alert">@_error</p>
}

@code {
    [Parameter] public int? Value { get; set; }
    [Parameter] public EventCallback<int?> ValueChanged { get; set; }
    [Parameter] public string Id { get; set; } = "category";
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Optional floating label for the select (e.g. "Category").</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Text for the null option — "(no category)" in forms, "All categories" in filters.</summary>
    [Parameter] public string EmptyLabel { get; set; } = "(no category)";

    private IReadOnlyList<CategoryResponse> _categories = [];
    private bool _loading = true;
    private string? _error;

    private IEnumerable<CategoryResponse> Roots =>
        _categories.Where(c => c.ParentId is null);

    private IEnumerable<CategoryResponse> ChildrenOf(int parentId) =>
        _categories.Where(c => c.ParentId == parentId);

    protected override async Task OnInitializedAsync()
    {
        var outcome = await CategoryApi.ListAsync();
        if (outcome.Succeeded)
            _categories = outcome.Data!;
        else
            _error = outcome.Error;
        _loading = false;
    }

    private Task OnValueChangedAsync(int? value) => ValueChanged.InvokeAsync(value);

    // Selected-value display (the null option would otherwise render blank).
    private string DisplayName(int? id) =>
        id is null ? EmptyLabel : _categories.FirstOrDefault(c => c.Id == id)?.Name ?? EmptyLabel;
}
