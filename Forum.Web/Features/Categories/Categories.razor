@* Forum.Web/Features/Categories/Categories.razor *@
@page "/categories"
@inject ICategoryApiClient CategoryApi
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Categories</PageTitle>

<h1 class="forum-h1">Categories</h1>

@if (_loading)
{
    <div class="flex flex-col gap-3">
        @for (var i = 0; i < 3; i++)
        {
            <MudPaper Elevation="0" Class="forum-card pa-4">
                <MudSkeleton Width="35%" Height="28px" />
                <MudSkeleton Width="20%" />
            </MudPaper>
        }
    </div>
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" role="alert">@_error</MudAlert>
}
else
{
    @if (_categories.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No categories yet.</MudAlert>
    }
    else
    {
        <div class="flex flex-col gap-3">
            @foreach (var root in Roots)
            {
                <MudPaper Elevation="0" Class="forum-card pa-4" @key="root.Id">
                    @RenderCategory(root)
                    @foreach (var child in ChildrenOf(root.Id))
                    {
                        <div class="category-child">@RenderCategory(child)</div>
                    }
                </MudPaper>
            }
        </div>
    }

    <AuthorizeView Roles="Moderator" Context="authContext">
        <MudPaper Elevation="0" Class="forum-card pa-4 mt-6">
            <div class="flex items-center gap-2 mb-3">
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Moderator</MudChip>
                <span class="forum-meta">Create, rename, and delete categories below.</span>
            </div>

            <h3 class="forum-h3">New category</h3>
            <EditForm Model="_createModel" OnValidSubmit="CreateAsync" FormName="category-create">
                <DataAnnotationsValidator />

                <MudTextField Label="Name" @bind-Value="_createModel.Name"
                              For="() => _createModel.Name" Variant="Variant.Outlined" Class="mb-4" />

                <div class="max-w-xs mb-4">
                    <MudSelect T="int?" Label="Parent (optional — makes this a sub-category)"
                               @bind-Value="_createModel.ParentId" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem T="int?" Value="@((int?)null)">(none — root category)</MudSelectItem>
                        @foreach (var root in Roots)
                        {
                            <MudSelectItem T="int?" Value="@((int?)root.Id)">@root.Name</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                @if (_createError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" role="alert">@_createError</MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="_createBusy">
                    @(_createBusy ? "Creating…" : "Create category")
                </MudButton>
            </EditForm>
        </MudPaper>
    </AuthorizeView>
}

@code {
    // Shared row template: name link + thread count + moderator rename/delete
    // controls (inline edit swaps the row for a small form).
    private RenderFragment RenderCategory(CategoryResponse category) => __builder =>
    {
        @if (_editingId == category.Id)
        {
            <EditForm Model="_editModel" OnValidSubmit="SaveEditAsync" FormName="@($"category-edit-{category.Id}")">
                <DataAnnotationsValidator />
                <div class="flex items-center gap-2 flex-wrap">
                    <div class="w-64">
                        <MudTextField @bind-Value="_editModel.Name" For="() => _editModel.Name"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </div>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Small" Disabled="_editBusy">
                        @(_editBusy ? "Saving…" : "Save")
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Text" Size="Size.Small"
                               OnClick="CancelEdit">Cancel</MudButton>
                </div>
                @if (_editError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2" role="alert">@_editError</MudAlert>
                }
            </EditForm>
        }
        else
        {
            <span class="inline-flex items-center gap-2 flex-wrap">
                <a class="forum-title" href="@($"/threads?categoryId={category.Id}")">@category.Name</a>
                <span class="forum-meta">· @category.ThreadCount thread@(category.ThreadCount == 1 ? "" : "s")</span>
                <AuthorizeView Roles="Moderator" Context="modContext">
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => BeginEdit(category)">Rename</MudButton>
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                               OnClick="() => DeleteAsync(category)" Disabled="@(_deleteBusyId == category.Id)">
                        @(_deleteBusyId == category.Id ? "Deleting…" : "Delete")
                    </MudButton>
                </AuthorizeView>
            </span>
            @if (_actionErrorId == category.Id && _actionError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2" role="alert">@_actionError</MudAlert>
            }
        }
    };
}
