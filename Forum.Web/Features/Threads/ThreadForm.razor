@* Forum.Web/Features/Threads/ThreadForm.razor *@
@* Reusable thread editor. Child→parent submit via EventCallback. *@

<EditForm Model="Model" OnValidSubmit="OnValidSubmitAsync" FormName="thread-form">
    <DataAnnotationsValidator />

    <MudTextField Label="Title" @bind-Value="Model.Title" For="() => Model.Title"
                  Variant="Variant.Outlined" Class="mb-4" />

    <div class="mb-4">
        <label class="forum-label" for="body">Body</label>
        <MarkdownEditor Id="body" Rows="10" @bind-Value="Model.Body" />
        <ValidationMessage For="() => Model.Body" />
    </div>

    <div class="max-w-xs mb-4">
        <CategoryPicker Id="category" Label="Category" @bind-Value="Model.CategoryId" />
    </div>

    <MudTextField Label="Tags" @bind-Value="Model.TagsInput" For="() => Model.TagsInput"
                  Variant="Variant.Outlined" Placeholder="api, ef core, help"
                  HelperText="Comma-separated, up to 5 tags." Class="mb-4" />

    @if (Error is not null)
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" role="alert">@Error</MudAlert>
    }

    <div class="flex items-center gap-2">
        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="Busy">
            @(Busy ? $"{SubmitLabel}…" : SubmitLabel)
        </MudButton>
        <MudButton Variant="Variant.Text" Href="@CancelHref">Cancel</MudButton>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public ThreadEditModel Model { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnSubmit { get; set; }
    [Parameter] public string SubmitLabel { get; set; } = "Save";
    [Parameter] public string CancelHref { get; set; } = "/threads";
    [Parameter] public bool Busy { get; set; }
    [Parameter] public string? Error { get; set; }

    private Task OnValidSubmitAsync() => OnSubmit.InvokeAsync();
}
