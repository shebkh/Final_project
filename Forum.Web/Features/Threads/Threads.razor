@* Forum.Web/Features/Threads/Threads.razor *@
@page "/threads"
@inject IThreadApiClient ThreadApi
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Threads</PageTitle>

<div class="flex items-center justify-between flex-wrap gap-3 mb-4">
    <h1 class="forum-h1 !mb-0">Threads</h1>
    <AuthorizeView>
        <Authorized>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/threads/new"
                       StartIcon="@Icons.Material.Filled.Add">Start a thread</MudButton>
        </Authorized>
    </AuthorizeView>
</div>

<div class="max-w-xs mb-4">
    <CategoryPicker Id="thread-filter" Label="Category" EmptyLabel="All categories"
                    Value="CategoryId" ValueChanged="OnFilterChangedAsync" />
</div>

@if (Tag is not null)
{
    <div class="flex items-center flex-wrap gap-2 mb-4 forum-meta">
        Showing threads tagged
        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">#@Tag</MudChip>
        <MudButton Variant="Variant.Text" Size="Size.Small"
                   Href="@(CategoryId is null ? "/threads" : $"/threads?categoryId={CategoryId}")">clear</MudButton>
    </div>
}

@if (_loading)
{
    <div class="flex flex-col gap-3">
        @for (var i = 0; i < 3; i++)
        {
            <MudPaper Elevation="0" Class="forum-card pa-4">
                <MudSkeleton Width="45%" Height="28px" />
                <MudSkeleton Width="90%" />
                <MudSkeleton Width="30%" />
            </MudPaper>
        }
    </div>
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" role="alert">@_error</MudAlert>
}
else if (_threads.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        @(CategoryId is null
            ? "No threads yet. Be the first to start a discussion."
            : "No threads in this category yet.")
    </MudAlert>
}
else
{
    <div class="flex flex-col gap-3">
        @foreach (var thread in _threads)
        {
            <MudPaper Elevation="0" Class="forum-card forum-card-hover pa-4" @key="thread.Id">
                <div class="flex items-center flex-wrap gap-2">
                    @if (thread.IsPinned)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.PushPin" title="Pinned by a moderator">Pinned</MudChip>
                    }
                    @if (thread.IsLocked)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.Lock" title="Locked by a moderator">Locked</MudChip>
                    }
                    @if (thread.CategoryName is not null)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                 Href="@($"/threads?categoryId={thread.CategoryId}")">@thread.CategoryName</MudChip>
                    }
                    <a class="forum-title" href="@($"/threads/{thread.Id}")">@thread.Title</a>
                    @foreach (var tag in thread.Tags)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text"
                                 Href="@($"/threads?tag={Uri.EscapeDataString(tag)}")">#@tag</MudChip>
                    }
                </div>
                <p class="forum-excerpt">@thread.Excerpt</p>
                <div class="forum-meta">
                    by <a class="forum-author" href="@($"/users/{thread.AuthorId}")">@thread.AuthorUserName</a>
                    · @thread.CreatedAtUtc.ToLocalTime().ToString("g")
                </div>
            </MudPaper>
        }
    </div>
}
