@* Forum.Web/Features/Threads/Threads.razor *@
@page "/threads"
@inject IThreadApiClient ThreadApi
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Threads</PageTitle>

<div class="threads-header">
    <h1>Threads</h1>
    <AuthorizeView>
        <Authorized>
            <a class="btn btn-primary btn-inline" href="/threads/new">Start a thread</a>
        </Authorized>
    </AuthorizeView>
</div>

<div class="form-group threads-filter">
    <label for="thread-filter">Category</label>
    <CategoryPicker Id="thread-filter" EmptyLabel="All categories"
                    Value="CategoryId" ValueChanged="OnFilterChangedAsync" />
</div>

@if (Tag is not null)
{
    <p class="thread-meta threads-tag-filter">
        Showing threads tagged <span class="badge badge-tag">#@Tag</span>
        <a class="btn btn-link-dark" href="@(CategoryId is null ? "/threads" : $"/threads?categoryId={CategoryId}")">clear</a>
    </p>
}

@if (_loading)
{
    <p>Loading threads…</p>
}
else if (_error is not null)
{
    <p class="auth-error" role="alert">@_error</p>
}
else if (_threads.Count == 0)
{
    <p>
        @(CategoryId is null
            ? "No threads yet. Be the first to start a discussion."
            : "No threads in this category yet.")
    </p>
}
else
{
    <ul class="thread-list">
        @foreach (var thread in _threads)
        {
            <li class="thread-card">
                @if (thread.IsPinned)
                {
                    <span class="badge badge-pinned" title="Pinned by a moderator">📌 Pinned</span>
                }
                @if (thread.IsLocked)
                {
                    <span class="badge badge-locked" title="Locked by a moderator">🔒 Locked</span>
                }
                @if (thread.CategoryName is not null)
                {
                    <a class="badge badge-category" href="@($"/threads?categoryId={thread.CategoryId}")">@thread.CategoryName</a>
                }
                <a class="thread-title" href="@($"/threads/{thread.Id}")">@thread.Title</a>
                @foreach (var tag in thread.Tags)
                {
                    <a class="badge badge-tag" href="@($"/threads?tag={Uri.EscapeDataString(tag)}")">#@tag</a>
                }
                <p class="thread-excerpt">@thread.Excerpt</p>
                <div class="thread-meta">
                    by <a class="author-link" href="@($"/users/{thread.AuthorId}")">@thread.AuthorUserName</a>
                    · @thread.CreatedAtUtc.ToLocalTime().ToString("g")
                </div>
            </li>
        }
    </ul>
}
