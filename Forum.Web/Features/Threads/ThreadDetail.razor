@* Forum.Web/Features/Threads/ThreadDetail.razor *@
@page "/threads/{Id:int}"
@inject IThreadApiClient ThreadApi
@inject IModerationApiClient ModerationApi
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@(_thread?.Title ?? "Thread")</PageTitle>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_error is not null)
{
    <p class="auth-error" role="alert">@_error</p>
    <a class="btn btn-link-dark" href="/threads">Back to threads</a>
}
else if (_thread is not null)
{
    <article class="thread-detail">
        <h1>
            @if (_thread.IsPinned)
            {
                <span class="badge badge-pinned" title="Pinned by a moderator">📌 Pinned</span>
            }
            @if (_thread.IsLocked)
            {
                <span class="badge badge-locked" title="Locked by a moderator">🔒 Locked</span>
            }
            @_thread.Title
        </h1>
        <div class="thread-meta">
            @if (_thread.CategoryName is not null)
            {
                <a class="badge badge-category" href="@($"/threads?categoryId={_thread.CategoryId}")">@_thread.CategoryName</a>
            }
            by <a class="author-link" href="@($"/users/{_thread.AuthorId}")">@_thread.AuthorUserName</a>
            · @_thread.CreatedAtUtc.ToLocalTime().ToString("g")
            @if (_thread.UpdatedAtUtc > _thread.CreatedAtUtc)
            {
                <span> · edited @_thread.UpdatedAtUtc.ToLocalTime().ToString("g")</span>
            }
        </div>

        <div class="thread-body">@_thread.Body</div>

        <AuthorizeView Roles="Moderator">
            <div class="mod-bar">
                <span class="mod-bar-label">Moderator</span>
                <button class="btn btn-link-dark" @onclick="TogglePinAsync" disabled="@_modBusy">
                    @(_thread.IsPinned ? "Unpin" : "Pin")
                </button>
                <button class="btn btn-link-dark" @onclick="ToggleLockAsync" disabled="@_modBusy">
                    @(_thread.IsLocked ? "Unlock" : "Lock")
                </button>
                <CategoryPicker Id="mod-move-category" EmptyLabel="(no category)"
                                @bind-Value="_moveCategoryId" Disabled="_modBusy" />
                <button class="btn btn-link-dark" @onclick="MoveAsync"
                        disabled="@(_modBusy || _moveCategoryId == _thread.CategoryId)">
                    Move
                </button>
                @if (_modError is not null)
                {
                    <span class="auth-error" role="alert">@_modError</span>
                }
            </div>
        </AuthorizeView>

        <VoteBox Kind="VoteTargetKind.Thread" TargetId="Id" />

        @if (_isOwner || _isModerator)
        {
            <div class="form-actions">
                @if (_isOwner)
                {
                    <a class="btn btn-primary btn-inline" href="@($"/threads/{Id}/edit")">Edit</a>
                }
                <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_deleting">
                    @(_deleting ? "Deleting…" : "Delete")
                </button>
            </div>
            @if (_actionError is not null)
            {
                <p class="auth-error" role="alert">@_actionError</p>
            }
        }
    </article>

    <PostList ThreadId="Id" Locked="_thread.IsLocked" />

    <a class="btn btn-link-dark" href="/threads">← Back to threads</a>
}
