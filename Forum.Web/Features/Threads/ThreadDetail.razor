@* Forum.Web/Features/Threads/ThreadDetail.razor *@
@page "/threads/{Id:int}"
@inject IThreadApiClient ThreadApi
@inject IModerationApiClient ModerationApi
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@(_thread?.Title ?? "Thread")</PageTitle>

@if (_loading)
{
    <MudPaper Elevation="0" Class="forum-card pa-6">
        <MudSkeleton Width="55%" Height="36px" />
        <MudSkeleton Width="35%" />
        <MudSkeleton Width="100%" Height="80px" />
    </MudPaper>
}
else if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" role="alert">@_error</MudAlert>
    <MudButton Variant="Variant.Text" Href="/threads">Back to threads</MudButton>
}
else if (_thread is not null)
{
    <article>
        <MudPaper Elevation="0" Class="forum-card pa-6">
            @if (_thread.IsPinned || _thread.IsLocked)
            {
                <div class="flex items-center flex-wrap gap-2 mb-2">
                    @if (_thread.IsPinned)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.PushPin" title="Pinned by a moderator">Pinned</MudChip>
                    }
                    @if (_thread.IsLocked)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.Lock" title="Locked by a moderator">Locked</MudChip>
                    }
                </div>
            }
            <h1 class="forum-h1">@_thread.Title</h1>
            <div class="flex items-center flex-wrap gap-2 forum-meta mb-4">
                @if (_thread.CategoryName is not null)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                             Href="@($"/threads?categoryId={_thread.CategoryId}")">@_thread.CategoryName</MudChip>
                }
                @foreach (var tag in _thread.Tags)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text"
                             Href="@($"/threads?tag={Uri.EscapeDataString(tag)}")">#@tag</MudChip>
                }
                <span>
                    by <a class="forum-author" href="@($"/users/{_thread.AuthorId}")">@_thread.AuthorUserName</a>
                    · @_thread.CreatedAtUtc.ToLocalTime().ToString("g")
                    @if (_thread.UpdatedAtUtc > _thread.CreatedAtUtc)
                    {
                        <span> · edited @_thread.UpdatedAtUtc.ToLocalTime().ToString("g")</span>
                    }
                </span>
            </div>

            <MarkdownBody Content="@_thread.Body" CssClass="thread-body" />

            <AuthorizeView Roles="Moderator">
                <MudPaper Outlined="true" Class="forum-modbar pa-3 mt-4">
                    <div class="flex items-center flex-wrap gap-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Moderator</MudChip>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="TogglePinAsync" Disabled="_modBusy">
                            @(_thread.IsPinned ? "Unpin" : "Pin")
                        </MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ToggleLockAsync" Disabled="_modBusy">
                            @(_thread.IsLocked ? "Unlock" : "Lock")
                        </MudButton>
                        <div class="w-52">
                            <CategoryPicker Id="mod-move-category" EmptyLabel="(no category)"
                                            @bind-Value="_moveCategoryId" Disabled="_modBusy" />
                        </div>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="MoveAsync"
                                   Disabled="@(_modBusy || _moveCategoryId == _thread.CategoryId)">
                            Move
                        </MudButton>
                        @if (_modError is not null)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" role="alert">@_modError</MudAlert>
                        }
                    </div>
                </MudPaper>
            </AuthorizeView>

            <div class="mt-4">
                <VoteBox Kind="VoteTargetKind.Thread" TargetId="Id" />
            </div>

            @if (_isOwner || _isModerator)
            {
                <div class="flex items-center gap-2 mt-4">
                    @if (_isOwner)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/threads/{Id}/edit")">Edit</MudButton>
                    }
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="DeleteAsync" Disabled="_deleting">
                        @(_deleting ? "Deleting…" : "Delete")
                    </MudButton>
                </div>
                @if (_actionError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2" role="alert">@_actionError</MudAlert>
                }
            }
        </MudPaper>
    </article>

    <PostList ThreadId="Id" Locked="_thread.IsLocked" />

    <MudButton Variant="Variant.Text" Href="/threads" Class="mt-4"
               StartIcon="@Icons.Material.Filled.ArrowBack">Back to threads</MudButton>
}
