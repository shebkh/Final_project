@* Forum.Web/Features/Auth/Register.razor *@
@page "/register"
@inject IAuthManager AuthManager
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Create an account</PageTitle>

<div class="auth-card">
    <h1>Create an account</h1>

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="register">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label for="username">Username</label>
            <InputText id="username" class="form-control" @bind-Value="_model.UserName" />
            <ValidationMessage For="() => _model.UserName" />
        </div>

        <div class="form-group">
            <label for="email">Email</label>
            <InputText id="email" class="form-control" @bind-Value="_model.Email" />
            <ValidationMessage For="() => _model.Email" />
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" />
            <ValidationMessage For="() => _model.Password" />
            <small class="form-hint">At least 8 characters, with upper, lower, and a digit.</small>
        </div>

        @if (_error is not null)
        {
            <p class="auth-error" role="alert">@_error</p>
        }

        <button type="submit" class="btn btn-primary" disabled="@_busy">
            @(_busy ? "Creating account…" : "Register")
        </button>
    </EditForm>

    <p class="auth-switch">Already have an account? <a href="/login">Sign in</a></p>
</div>

@code {
    private readonly RegisterModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task HandleSubmitAsync()
    {
        _busy = true;
        _error = null;

        var outcome = await AuthManager.RegisterAsync(_model);
        _busy = false;

        if (outcome.Succeeded)
            Navigation.NavigateTo("/");
        else
            _error = outcome.Error;
    }
}
