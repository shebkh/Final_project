@* Forum.Web/Features/Auth/Register.razor *@
@page "/register"
@inject IAuthManager AuthManager
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Create an account</PageTitle>

<div class="max-w-md mx-auto mt-6">
    <MudPaper Elevation="0" Class="forum-card pa-6">
        <h1 class="forum-h1">Create an account</h1>

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="register">
            <DataAnnotationsValidator />

            <MudTextField Label="Username" @bind-Value="_model.UserName"
                          For="() => _model.UserName" Variant="Variant.Outlined" Class="mb-4" />

            <MudTextField Label="Email" @bind-Value="_model.Email"
                          For="() => _model.Email" Variant="Variant.Outlined" Class="mb-4" />

            <MudTextField Label="Password" @bind-Value="_model.Password"
                          For="() => _model.Password" InputType="InputType.Password"
                          Variant="Variant.Outlined" Class="mb-4"
                          HelperText="At least 8 characters, with upper, lower, and a digit." />

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" role="alert">@_error</MudAlert>
            }

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Disabled="_busy">
                @(_busy ? "Creating account…" : "Register")
            </MudButton>
        </EditForm>

        <p class="forum-switch">Already have an account? <a href="/login">Sign in</a></p>
    </MudPaper>
</div>

@code {
    private readonly RegisterModel _model = new();
    private string? _error;
    private bool _busy;

    private async Task HandleSubmitAsync()
    {
        _busy = true;
        _error = null;

        var outcome = await AuthManager.RegisterAsync(_model);
        _busy = false;

        if (outcome.Succeeded)
            Navigation.NavigateTo("/home");
        else
            _error = outcome.Error;
    }
}
