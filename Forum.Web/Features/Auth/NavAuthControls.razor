@* Forum.Web/Features/Auth/NavAuthControls.razor *@
@* The interactive slice of the top nav: the sign-out button needs an event
   handler, so this component owns the render mode. MainLayout stays static —
   a layout cannot declare @rendermode because @Body can't cross the boundary. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAuthManager AuthManager
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <span class="forum-greeting hidden sm:inline">Hi, @context.User.Identity?.Name</span>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LogoutAsync">Sign out</MudButton>
    </Authorized>
    <NotAuthorized>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Sign in</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/register" Class="ml-2">Register</MudButton>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task LogoutAsync()
    {
        await AuthManager.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
