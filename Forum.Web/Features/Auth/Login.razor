@* Forum.Web/Features/Auth/Login.razor *@
@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthManager AuthManager
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Sign in</PageTitle>

<div class="max-w-md mx-auto mt-6">
    <MudPaper Elevation="0" Class="forum-card pa-6">
        <h1 class="forum-h1">Sign in</h1>

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="login">
            <DataAnnotationsValidator />

            <MudTextField Label="Username or email" @bind-Value="_model.UserNameOrEmail"
                          For="() => _model.UserNameOrEmail" Variant="Variant.Outlined" Class="mb-4" />

            <MudTextField Label="Password" @bind-Value="_model.Password"
                          For="() => _model.Password" InputType="InputType.Password"
                          Variant="Variant.Outlined" Class="mb-4" />

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" role="alert">@_error</MudAlert>
            }

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Disabled="_busy">
                @(_busy ? "Signing in…" : "Sign in")
            </MudButton>
        </EditForm>

        <p class="forum-switch">No account? <a href="/register">Register</a></p>
    </MudPaper>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _busy;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleSubmitAsync()
    {
        _busy = true;
        _error = null;

        var outcome = await AuthManager.LoginAsync(_model);
        _busy = false;

        if (outcome.Succeeded)
            Navigation.NavigateTo(SafeReturnUrl());
        else
            _error = outcome.Error;
    }

    // Only base-relative destinations — anything absolute or protocol-relative
    // ("//evil.example") would be an open redirect.
    private string SafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/home";
        if (ReturnUrl.StartsWith("//") || ReturnUrl.StartsWith("/\\") || ReturnUrl.Contains(':'))
            return "/home";
        return ReturnUrl.StartsWith('/') ? ReturnUrl : "/" + ReturnUrl;
    }
}
