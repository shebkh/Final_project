@* Forum.Web/Features/Votes/VoteBox.razor *@
@* Up/down vote control with score. Reusable for threads and posts. *@
@* Embedded in host pages (ThreadDetail, PostList); not routable, so no @page/@rendermode —
   inherits the host page's interactive, non-prerendered render mode. *@

<div class="inline-flex items-center gap-1">
    <AuthorizeView>
        <Authorized>
            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small"
                           Color="@(_tally?.MyVote == 1 ? Color.Primary : Color.Default)"
                           title="Up-vote" Disabled="_busy" OnClick="() => CastAsync(1)" />
            <span class="vote-score @ScoreClass">@(_tally?.Score ?? 0)</span>
            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small"
                           Color="@(_tally?.MyVote == -1 ? Color.Error : Color.Default)"
                           title="Down-vote" Disabled="_busy" OnClick="() => CastAsync(-1)" />
        </Authorized>
        <NotAuthorized>
            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small"
                     Class="vote-readonly" title="Sign in to vote" />
            <span class="vote-score @ScoreClass">@(_tally?.Score ?? 0)</span>
            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small"
                     Class="vote-readonly" title="Sign in to vote" />
        </NotAuthorized>
    </AuthorizeView>

    @if (_error is not null)
    {
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" Color="Color.Error"
                 role="alert" title="@_error" />
    }
</div>
