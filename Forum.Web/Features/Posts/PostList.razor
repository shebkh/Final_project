@* Forum.Web/Features/Posts/PostList.razor *@
@* Renders the replies for a thread and (when signed in) an add-reply form. *@
@* Embedded in ThreadDetail; not a routable page, so no @page/@rendermode here —
   it inherits the parent page's interactive, non-prerendered render mode. *@

<section class="mt-6">
    <h2 class="forum-h2">Replies@(_count > 0 ? $" ({_count})" : "")</h2>

    @if (_loading)
    {
        <div class="flex flex-col gap-3">
            @for (var i = 0; i < 2; i++)
            {
                <MudPaper Elevation="0" Class="forum-card pa-4">
                    <MudSkeleton Width="85%" />
                    <MudSkeleton Width="30%" />
                </MudPaper>
            }
        </div>
    }
    else if (_loadError is not null)
    {
        <MudAlert Severity="Severity.Error" role="alert">@_loadError</MudAlert>
    }
    else
    {
        @if (_posts.Count == 0)
        {
            <p class="forum-empty">No replies yet.</p>
        }
        else
        {
            <div class="flex flex-col gap-3">
                @foreach (var post in _posts)
                {
                    <MudPaper Elevation="0" Class="forum-card pa-4" @key="post.Id">
                        @if (_editingId == post.Id)
                        {
                            <PostForm Model="_editModel"
                                      OnSubmit="SaveEditAsync"
                                      OnCancel="CancelEdit"
                                      SubmitLabel="Save"
                                      FormName="@($"edit-{post.Id}")"
                                      Busy="IsRowBusy(post.Id)"
                                      Error="_editError" />
                        }
                        else
                        {
                            <MarkdownBody Content="@post.Body" CssClass="post-body" />
                            <div class="forum-meta mt-2">
                                by <a class="forum-author" href="@($"/users/{post.AuthorId}")">@post.AuthorUserName</a>
                                · @post.CreatedAtUtc.ToLocalTime().ToString("g")
                                @if (post.UpdatedAtUtc > post.CreatedAtUtc)
                                {
                                    <span> · edited</span>
                                }
                            </div>
                            <div class="flex items-center flex-wrap gap-2 mt-2">
                                <VoteBox Kind="VoteTargetKind.Post" TargetId="post.Id" />
                                @if (CanQuote)
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small"
                                               OnClick="() => QuoteReply(post)"
                                               Disabled="@IsRowBusy(post.Id)"
                                               StartIcon="@Icons.Material.Filled.FormatQuote">Quote</MudButton>
                                }
                                @if (CanEdit(post) && !Locked)
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small"
                                               OnClick="() => BeginEdit(post)"
                                               Disabled="@IsRowBusy(post.Id)">Edit</MudButton>
                                }
                                @if (CanDelete(post))
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                                               OnClick="() => DeleteAsync(post.Id)"
                                               Disabled="@IsRowBusy(post.Id)">Delete</MudButton>
                                }
                            </div>
                        }
                    </MudPaper>
                }
            </div>
        }

        @if (_actionError is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2" role="alert">@_actionError</MudAlert>
        }

        @if (Locked)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-4" Icon="@Icons.Material.Filled.Lock" role="status">
                This thread is locked. New replies are disabled.
            </MudAlert>
        }
        else
        {
            <AuthorizeView>
                <Authorized>
                    <MudPaper Elevation="0" Class="forum-card pa-4 mt-4">
                        <PostForm @ref="_addForm"
                                  Model="_newModel"
                                  OnSubmit="AddReplyAsync"
                                  SubmitLabel="Post reply"
                                  Label="Add a reply"
                                  FormName="add-reply"
                                  Busy="_addBusy"
                                  Error="_addError" />
                    </MudPaper>
                </Authorized>
                <NotAuthorized>
                    <p class="forum-empty mt-4"><a href="/login">Sign in</a> to reply.</p>
                </NotAuthorized>
            </AuthorizeView>
        }
    }
</section>
